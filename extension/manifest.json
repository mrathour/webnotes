{
  "manifest_version": 3,
  "name": "WebNotes",
  "version": "1.0",
  "description": "Capture any webpage element, generate AI study notes, and sync them to Notion.",
  "permissions": ["activeTab", "scripting", "identity", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.notion.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Element Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
